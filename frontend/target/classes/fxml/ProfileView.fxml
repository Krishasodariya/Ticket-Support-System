<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ticketsystem.frontend.controller.ProfileController" stylesheets="@../css/styles.css" styleClass="root">
    <left>
        <VBox styleClass="sidebar" prefWidth="210">
            <VBox>
                <padding><Insets top="20" right="16" bottom="16" left="16"/></padding>
                <Label text="Ticket Support System" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0EA5E9;" />
            </VBox>
            <Separator styleClass="separator" />
            <VBox VBox.vgrow="ALWAYS" />
            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#handleBack" styleClass="nav-item">
                <padding><Insets top="9" right="16" bottom="9" left="16"/></padding>
                <Circle radius="4" fill="#EF4444" />
                <Label text="Zurück" styleClass="text-danger" />
            </HBox>
        </VBox>
    </left>

    <top>
        <HBox styleClass="topbar" prefHeight="48" alignment="CENTER_LEFT">
            <padding><Insets top="0" right="16" bottom="0" left="16"/></padding>
            <Label text="Konto  /  Profil &amp; Sicherheit" styleClass="text-muted" style="-fx-font-size: 12px;" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <HBox spacing="20">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <VBox styleClass="card" prefWidth="280" minWidth="280" spacing="15">
                    <VBox alignment="CENTER" spacing="10">
                        <StackPane>
                            <Circle fx:id="avatarBackground" radius="44" styleClass="profile-avatar" />
                            <ImageView fx:id="profileImageView" fitWidth="88" fitHeight="88" preserveRatio="false" smooth="true" visible="false" managed="false" />
                            <Label fx:id="avatarInitials" text="JD" style="-fx-font-size: 22px; -fx-text-fill: white; -fx-font-weight: bold;" />
                        </StackPane>
                        <Label fx:id="nameLabel" text="Vorname Nachname" styleClass="heading-md" />
                        <Label fx:id="roleBadge" text="CUSTOMER" styleClass="badge, badge-customer" />
                    </VBox>
                    <Separator styleClass="separator" />
                    <Label text="PROFILMENÜ" styleClass="nav-section-label" />
                    <VBox spacing="6">
                        <Label text="Persönliche Daten" styleClass="nav-item, nav-item-active, text-primary" maxWidth="Infinity" />
                        <Label text="Passwort ändern" styleClass="nav-item, text-secondary" maxWidth="Infinity" />
                        <Button text="Dark/Light Mode wechseln" onAction="#handleToggleTheme" styleClass="btn-ghost" maxWidth="Infinity" />
                    </VBox>
                </VBox>

                <StackPane HBox.hgrow="ALWAYS">
                    <VBox spacing="20">
                        <VBox styleClass="card" spacing="15">
                            <Label text="PERSÖNLICHE DATEN" styleClass="profile-section-label" />
                            <GridPane hgap="12" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50" />
                                    <ColumnConstraints percentWidth="50" />
                                </columnConstraints>
                                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label text="Benutzername *" styleClass="text-muted" />
                                    <TextField fx:id="usernameField" styleClass="text-field" disable="true" />
                                </VBox>
                                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label text="E-Mail *" styleClass="text-muted" />
                                    <TextField fx:id="emailField" styleClass="text-field" />
                                </VBox>
                                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <Label text="Geburtsdatum" styleClass="text-muted" />
                                    <DatePicker fx:id="birthDatePicker" styleClass="text-field" maxWidth="Infinity" />
                                </VBox>
                                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <Label text="Profilbild URL" styleClass="text-muted" />
                                    <TextField fx:id="profilePicField" styleClass="text-field" />
                                </VBox>
                            </GridPane>
                            <HBox alignment="CENTER_RIGHT" spacing="10">
                                <Button text="Abbrechen" onAction="#handleBack" styleClass="btn-ghost" />
                                <Button text="Profil speichern" onAction="#handleSave" styleClass="btn-primary" />
                            </HBox>
                        </VBox>

                        <VBox styleClass="card" spacing="15">
                            <Label text="PASSWORT ÄNDERN" styleClass="profile-section-label" />
                            <GridPane hgap="12" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="33" />
                                    <ColumnConstraints percentWidth="33" />
                                    <ColumnConstraints percentWidth="34" />
                                </columnConstraints>
                                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label text="Aktuelles Passwort" styleClass="text-muted" />
                                    <PasswordField fx:id="currentPasswordField" styleClass="text-field" />
                                </VBox>
                                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label text="Neues Passwort" styleClass="text-muted" />
                                    <PasswordField fx:id="newPasswordField" styleClass="text-field" />
                                </VBox>
                                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                    <Label text="Passwort wiederholen" styleClass="text-muted" />
                                    <PasswordField fx:id="confirmPasswordField" styleClass="text-field" />
                                </VBox>
                            </GridPane>
                            <Label text="Mindestens 8 Zeichen, mit Buchstaben, Zahl und Sonderzeichen." styleClass="text-muted" />
                            <HBox alignment="CENTER_RIGHT" spacing="10">
                                <Button text="Passwort ändern" onAction="#handleChangePassword" styleClass="btn-primary" />
                            </HBox>
                        </VBox>
                    </VBox>
                </StackPane>
            </HBox>
        </ScrollPane>
    </center>
</BorderPane>
