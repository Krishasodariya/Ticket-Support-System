<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ticketsystem.frontend.controller.HomeController" style="-fx-background-color: linear-gradient(to bottom right, #1E3A8A, #3B82F6);">
    <VBox alignment="CENTER" spacing="20.0" styleClass="form-container" maxWidth="500" style="-fx-padding: 50;">
        <Label text="♾️" style="-fx-font-size: 64px; -fx-text-fill: #2563EB;" />
       <Label text="Ticket Support System" styleClass="title-label" />
        <Label text="Ihr professionelles Support-Ticket-System" styleClass="subtitle-label" />
        <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 30 0 0 0;">
            <Button text="Anmelden" onAction="#handleLogin" styleClass="primary-btn" style="-fx-pref-width: 150; -fx-pref-height: 45;" />
            <Button text="Registrieren" onAction="#handleRegister" styleClass="secondary-btn" style="-fx-pref-width: 150; -fx-pref-height: 45;" />
        </HBox>
    </VBox>
</VBox>
