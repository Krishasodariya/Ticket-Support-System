<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ticketsystem.frontend.controller.LoginController" stylesheets="@../css/styles.css" styleClass="register-root" onKeyPressed="#handleKeyPressed">
    <VBox alignment="CENTER" spacing="18" styleClass="register-card" maxWidth="430">
        <padding><Insets top="42" right="44" bottom="42" left="44" /></padding>
        <Label text="Ticket Support System" styleClass="register-brand" />
        <Label text="Anmelden" styleClass="register-title" />
        <Label text="Melden Sie sich an, um Tickets, Dashboard und Support-Aufgaben zu verwalten." styleClass="register-subtitle" wrapText="true" textAlignment="CENTER" />
        <VBox spacing="12" maxWidth="330">
            <TextField fx:id="usernameField" promptText="Benutzername" styleClass="text-field, register-input" />
            <PasswordField fx:id="passwordField" promptText="Passwort" styleClass="text-field, register-input" />
            <Label fx:id="errorLabel" text="Fehler" styleClass="register-error" visible="false" wrapText="true" />
            <Button text="Anmelden" onAction="#handleLogin" styleClass="btn-primary, register-button" maxWidth="Infinity" />
        </VBox>
        <Hyperlink text="Noch kein Konto? Registrieren" onAction="#handleRegisterLink" styleClass="register-link" />
        <Label text="Demo: admin/admin123 · agent/agent123 · customer/customer123" styleClass="register-subtitle" wrapText="true" textAlignment="CENTER" />
    </VBox>
</StackPane>
