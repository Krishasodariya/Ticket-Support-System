<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ticketsystem.frontend.controller.CustomerController" stylesheets="@../css/styles.css" styleClass="root">
    
    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="210">
            <VBox>
                <padding><Insets top="20" right="16" bottom="16" left="16"/></padding>
              <Label text="Ticket Support System" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0EA5E9;" />
            </VBox>
            
            <Label text="MEIN BEREICH" styleClass="nav-section-label" />
            
            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#showOverview" fx:id="navOverview" styleClass="nav-item">
                <padding><Insets top="9" right="16" bottom="9" left="16"/></padding>
                <Circle radius="4" fill="#0EA5E9" fx:id="dotOverview" />
                <Label text="Übersicht" styleClass="text-secondary" fx:id="labelOverview" />
            </HBox>
            
            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#showMyTickets" fx:id="navMyTickets" styleClass="nav-item">
                <padding><Insets top="9" right="16" bottom="9" left="16"/></padding>
                <Circle radius="4" fill="#475569" fx:id="dotMyTickets" />
                <Label text="Meine Tickets" styleClass="text-secondary" fx:id="labelMyTickets" />
            </HBox>
            
            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#showNewTicket" fx:id="navNewTicket" styleClass="nav-item">
                <padding><Insets top="9" right="16" bottom="9" left="16"/></padding>
                <Circle radius="4" fill="#475569" fx:id="dotNewTicket" />
                <Label text="Neues Ticket erstellen" styleClass="text-secondary" fx:id="labelNewTicket" />
            </HBox>

            <Label text="KONTO" styleClass="nav-section-label" />
            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#handleProfile" styleClass="nav-item">
                <padding><Insets top="9" right="16" bottom="9" left="16"/></padding>
                <Circle radius="4" fill="#475569" />
                <Label text="Mein Profil" styleClass="text-secondary" />
            </HBox>

            <VBox VBox.vgrow="ALWAYS" />
            <Separator styleClass="separator" />
            
            <HBox spacing="10" alignment="CENTER_LEFT">
                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                <StackPane>
                    <Circle fx:id="sidebarAvatarBackground" radius="16" fill="#0EA5E9" />
                    <ImageView fx:id="sidebarProfileImage" fitWidth="32" fitHeight="32" preserveRatio="false" smooth="true" visible="false" managed="false" />
                    <Label fx:id="sidebarInitials" text="JD" style="-fx-font-size: 10px; -fx-text-fill: white; -fx-font-weight: bold;" />
                </StackPane>
                <VBox>
                    <Label fx:id="sidebarName" text="Customer" style="-fx-font-size: 13px; -fx-text-fill: #F1F5F9;" />
                    <Label text="Customer" style="-fx-font-size: 11px; -fx-text-fill: #475569;" />
                </VBox>
            </HBox>
            
            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#handleLogout" styleClass="nav-item">
                <padding><Insets top="9" right="16" bottom="9" left="16"/></padding>
                <Circle radius="4" fill="#EF4444" />
                <Label text="Abmelden" styleClass="text-danger" />
            </HBox>
        </VBox>
    </left>

    <!-- TOPBAR -->
    <top>
        <HBox styleClass="topbar" prefHeight="48" alignment="CENTER_LEFT">
            <padding><Insets top="0" right="16" bottom="0" left="16"/></padding>
            <Label fx:id="breadcrumb" text="Customer  /  Übersicht" styleClass="text-muted" style="-fx-font-size: 12px;" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="12" alignment="CENTER">
                <TextField promptText="Suche..." styleClass="text-field" prefWidth="180" style="-fx-padding: 6 10;" />
<StackPane fx:id="notificationButton"
           styleClass="notification-pill"
           onMouseClicked="#handleNotifications"
           style="-fx-cursor: hand;">

    <Label text="🔔"
           style="-fx-font-size: 16px;" />

    <Label fx:id="notificationCountLabel"
           text="0"
           styleClass="notification-count"
           StackPane.alignment="TOP_RIGHT" />

</StackPane>
                <StackPane onMouseClicked="#handleProfile" style="-fx-cursor: hand;">
                    <Circle fx:id="topbarAvatarBackground" radius="14" fill="#0EA5E9" />
                    <ImageView fx:id="topbarProfileImage" fitWidth="28" fitHeight="28" preserveRatio="false" smooth="true" visible="false" managed="false" />
                    <Label fx:id="topbarInitials" text="JD" style="-fx-font-size: 10px; -fx-text-fill: white; -fx-font-weight: bold;" />
                </StackPane>
            </HBox>
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <StackPane>
            <!-- PANE: ÜBERSICHT -->
            <ScrollPane fx:id="paneOverview" fitToWidth="true" styleClass="scroll-pane">
                <VBox spacing="20">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <VBox spacing="5">
                        <padding><Insets top="0" right="0" bottom="20" left="0"/></padding>
                        <Label fx:id="greetingLabel" text="Hallo, Customer!" styleClass="heading-lg" />
                        <Label text="Hier ist die Übersicht Ihrer Tickets und Aktivitäten." styleClass="text-muted" style="-fx-font-size: 13px;" />
                    </VBox>

                    <!-- Stat Cards -->
                   <!-- Stat Cards -->
<HBox spacing="12">
    <VBox styleClass="stat-card stat-card-modern" HBox.hgrow="ALWAYS">
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="🎫" styleClass="stat-icon stat-icon-blue" />
            <VBox spacing="2">
                <Label fx:id="statTotal" text="-" styleClass="stat-value" />
                <Label text="Meine Tickets" styleClass="stat-label" />
                <Label text="Gesamt" styleClass="stat-sub text-muted" />
            </VBox>
        </HBox>
    </VBox>

    <VBox styleClass="stat-card stat-card-modern" HBox.hgrow="ALWAYS">
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="📂" styleClass="stat-icon stat-icon-green" />
            <VBox spacing="2">
                <Label fx:id="statOpen" text="-" styleClass="stat-value" />
                <Label text="Offen" styleClass="stat-label" />
                <Label text="Warten auf Bearbeitung" styleClass="stat-sub text-muted" />
            </VBox>
        </HBox>
    </VBox>

    <VBox styleClass="stat-card stat-card-modern" HBox.hgrow="ALWAYS">
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="🛠" styleClass="stat-icon stat-icon-orange" />
            <VBox spacing="2">
                <Label fx:id="statProgress" text="-" styleClass="stat-value" />
                <Label text="In Bearbeitung" styleClass="stat-label" />
                <Label text="Agent zugewiesen" styleClass="stat-sub text-muted" />
            </VBox>
        </HBox>
    </VBox>

    <VBox styleClass="stat-card stat-card-modern" HBox.hgrow="ALWAYS">
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="✅" styleClass="stat-icon stat-icon-cyan" />
            <VBox spacing="2">
                <Label fx:id="statResolved" text="-" styleClass="stat-value" />
                <Label text="Gelöst" styleClass="stat-label" />
                <Label text="Erfolgreich abgeschlossen" styleClass="stat-sub text-muted" />
            </VBox>
        </HBox>
    </VBox>
</HBox>

                    <HBox spacing="16">
                        <!-- Links: Aktive Tickets -->
                        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="12">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="MEINE AKTIVEN TICKETS" styleClass="label-uppercase" />
                                <Region HBox.hgrow="ALWAYS" />
                            </HBox>
                            <VBox fx:id="activeTicketsContainer" spacing="10">
                                <!-- Dynamically populated Ticket Cards -->
                            </VBox>
                            <HBox alignment="CENTER_RIGHT">
                                <Button text="Alle Tickets anzeigen →" onAction="#showMyTickets" style="-fx-background-color: transparent; -fx-text-fill: #0EA5E9; -fx-cursor: hand;" />
                            </HBox>
                        </VBox>

                        <!-- Rechts: Schnell-Erstellung & Aktivität -->
                        <VBox spacing="16" minWidth="300" prefWidth="350">
                            <VBox styleClass="card" spacing="12">
                                <Label text="SCHNELL-TICKET ERSTELLEN" styleClass="label-uppercase" />
                                <TextField fx:id="quickTitleField" promptText="Kurzbeschreibung des Problems..." styleClass="text-field" />
                                <ComboBox fx:id="quickPriorityCombo" promptText="Priorität" styleClass="combo-box" maxWidth="Infinity" />
                                <Button text="Ticket erstellen" onAction="#handleQuickCreate" styleClass="btn-primary" maxWidth="Infinity" />
                            </VBox>
                            
                            <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">
                                <Label text="LETZTE AKTIVITÄTEN" styleClass="label-uppercase" />
                                <VBox fx:id="activityContainer" spacing="10">
                                    <!-- Dynamically populated activities -->
                                    <Label text="Keine Aktivitäten verfügbar" styleClass="text-muted" />
                                </VBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>

            <!-- PANE: MEINE TICKETS -->
            <VBox fx:id="paneMyTickets" spacing="20" visible="false">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <ComboBox fx:id="filterStatusCombo" promptText="Status" prefWidth="120" styleClass="combo-box" />
                    <ComboBox fx:id="filterPriorityCombo" promptText="Priorität" prefWidth="120" styleClass="combo-box" />
                    <TextField fx:id="searchField" promptText="Titel suchen..." prefWidth="200" styleClass="text-field" />
                    <Button text="Filtern" onAction="#handleApplyFilter" styleClass="btn-primary" />
                    <Button text="Zurücksetzen" onAction="#handleClearFilter" styleClass="btn-ghost" />
                </HBox>

                <TableView fx:id="ticketTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colId" text="#" prefWidth="60" />
                        <TableColumn fx:id="colTitle" text="Titel" prefWidth="350" />
                        <TableColumn fx:id="colPriority" text="Priorität" prefWidth="100" />
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="130" />
                        <TableColumn fx:id="colAgent" text="Agent" prefWidth="120" />
                        <TableColumn fx:id="colCreatedAt" text="Erstellt" prefWidth="100" />
                        <TableColumn fx:id="colUpdatedAt" text="Geändert" prefWidth="100" />
                    </columns>
                </TableView>
            </VBox>

            <!-- PANE: NEUES TICKET -->
            <ScrollPane fx:id="paneNewTicket" fitToWidth="true" styleClass="scroll-pane" visible="false">
                <VBox alignment="TOP_CENTER">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <VBox styleClass="card" maxWidth="620" spacing="15">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                        <Label text="Neues Support-Ticket" styleClass="heading-md" />
                        <Label text="Beschreiben Sie Ihr Problem so genau wie möglich" styleClass="text-muted" style="-fx-font-size: 12px;" />
                        <Separator styleClass="separator" />

                        <Label text="TICKET-DETAILS" styleClass="label-uppercase" />
                        <TextField fx:id="newTitleField" promptText="Kurze Zusammenfassung..." styleClass="text-field" />
                        <TextArea fx:id="newDescField" promptText="Beschreiben Sie das Problem im Detail..." styleClass="text-area" prefRowCount="5" wrapText="true" />
                        
                        <HBox spacing="12">
                            <ComboBox fx:id="newPriorityCombo" promptText="Priorität *" styleClass="combo-box" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                            <ComboBox fx:id="newCategoryCombo" promptText="Kategorie *" styleClass="combo-box" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                        </HBox>
                        <TextField fx:id="newAttachmentNameField" promptText="Anhang-Dateiname optional, z.B. screenshot.png" styleClass="text-field" />
                        
                        <Label fx:id="newErrorLabel" text="Pflichtfeld" styleClass="text-danger" visible="false" />

                        <Region minHeight="10" />
                        <Separator styleClass="separator" />
                        <Label text="IHRE KONTAKTDATEN" styleClass="label-uppercase" />
                        
                        <HBox spacing="12">
                            <TextField fx:id="newFirstName" promptText="Vorname" styleClass="text-field" HBox.hgrow="ALWAYS" />
                            <TextField fx:id="newLastName" promptText="Nachname" styleClass="text-field" HBox.hgrow="ALWAYS" />
                        </HBox>
                        <HBox spacing="12">
                            <TextField fx:id="newEmail" promptText="E-Mail" styleClass="text-field" HBox.hgrow="ALWAYS" />
                            <TextField promptText="Telefon (optional)" styleClass="text-field" HBox.hgrow="ALWAYS" />
                        </HBox>

                        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 20 0 0 0;">
                            <Button text="Abbrechen" onAction="#showOverview" styleClass="btn-ghost" />
                            <Button text="Ticket erstellen" onAction="#handleCreateFullTicket" styleClass="btn-primary" />
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </StackPane>
    </center>
</BorderPane>
