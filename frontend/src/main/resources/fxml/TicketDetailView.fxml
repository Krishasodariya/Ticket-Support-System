<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ticketsystem.frontend.controller.TicketDetailController" stylesheets="@../css/styles.css" styleClass="main-container">
    <top>
        <HBox styleClass="header-bar" spacing="20" alignment="CENTER_LEFT">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Button text="&lt; Zurück" onAction="#handleBack" styleClass="btn-ghost" />
            <Label text="Ticket Details" styleClass="heading-lg" />
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.58" styleClass="content-area">
            <VBox spacing="15" styleClass="card">
                <Label fx:id="titleLabel" styleClass="heading-lg" wrapText="true"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Ticket-Nr.:" styleClass="field-label"/>
                    <Label fx:id="ticketNumberLabel" text="-" styleClass="text-primary"/>
                </HBox>
                <!-- [Nzchupa | 2026-06-13] TSS-011: Ticket-Metadaten als GridPane — gleichmäßige Spaltenbreiten -->
                <!-- Ticket metadata in GridPane — consistent column widths for all roles -->
                <GridPane hgap="0" vgap="5">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="20" minWidth="80"/>
                        <ColumnConstraints percentWidth="20" minWidth="80"/>
                        <ColumnConstraints percentWidth="20" minWidth="80"/>
                        <ColumnConstraints percentWidth="20" minWidth="80"/>
                        <ColumnConstraints percentWidth="20" minWidth="80"/>
                    </columnConstraints>
                    <Label text="Status"       styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label text="Priorität"    styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Erstellt von" styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <Label text="Agent"        styleClass="field-label" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                    <Label text="SLA"          styleClass="field-label" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                    <Label fx:id="statusLabel"    styleClass="badge"        GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="priorityLabel"  styleClass="badge"        GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label fx:id="createdByLabel" styleClass="text-primary" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <Label fx:id="assignedToLabel" styleClass="text-primary" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                    <HBox spacing="6" alignment="CENTER_LEFT" GridPane.columnIndex="4" GridPane.rowIndex="1">
                        <Circle fx:id="slaIndicator" radius="5" fill="#94A3B8"/>
                        <Label fx:id="slaLabel" text="-" styleClass="text-warning"/>
                    </HBox>
                </GridPane>
                <Separator/>
                <GridPane hgap="0" vgap="5">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25" minWidth="80"/>
                        <ColumnConstraints percentWidth="25" minWidth="80"/>
                        <ColumnConstraints percentWidth="25" minWidth="80"/>
                        <ColumnConstraints percentWidth="25" minWidth="80"/>
                    </columnConstraints>
                    <Label text="Fällig am"      styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label text="Anhang"         styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Lösungsgrund"   styleClass="field-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <Label text="Kundenfeedback" styleClass="field-label" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                    <Label fx:id="dueDateLabel"    text="-"           styleClass="text-muted" wrapText="true" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <!-- [Nzchupa | 2026-06-13] TSS-016: Anhang als klickbarer Hyperlink statt Label -->
                    <!-- Attachment shown as Hyperlink; click opens the file via Desktop.open() -->
                    <Hyperlink fx:id="attachmentLink" text="Kein Anhang" onAction="#handleOpenAttachment"
                               styleClass="text-muted" wrapText="true"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label fx:id="solutionLabel"   text="-"           styleClass="text-muted" wrapText="true" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <Label fx:id="ratingLabel"     text="-"           styleClass="text-muted" wrapText="true" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                </GridPane>
                <Label text="Beschreibung" styleClass="section-title"/>
                <TextArea fx:id="descriptionArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ComboBox fx:id="statusCombo" promptText="Neuer Status"/>
                    <Button fx:id="updateStatusBtn" text="Status aktualisieren" onAction="#handleUpdateStatus" styleClass="btn-primary"/>
                    <ComboBox fx:id="priorityCombo" promptText="Neue Priorität"/>
                    <Button fx:id="updatePriorityBtn" text="Priorität aktualisieren" onAction="#handleUpdatePriority" styleClass="btn-ghost"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ComboBox fx:id="agentCombo" promptText="Agent auswählen" prefWidth="260" />
                    <Button fx:id="assignAgentBtn" text="Agent zuweisen" onAction="#handleAssignAgent" styleClass="btn-ghost"/>
                    <Button fx:id="takeTicketBtn" text="Ticket übernehmen" onAction="#handleTakeTicket" styleClass="btn-primary"/>
                </HBox>
                <VBox spacing="8">
                    <TextArea fx:id="solutionReasonArea" promptText="Lösungsgrund eingeben, dann Ticket schließen..." prefRowCount="2" wrapText="true" />
                    <!-- [Nzchupa | 2026-06-13] TSS-016: FileChooser statt TextField — echter Dateipfad wird gespeichert -->
                    <!-- FileChooser replaces text field — stores real absolute path for Desktop.open() -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button fx:id="closeWithSolutionBtn" text="Mit Lösungsgrund schließen" onAction="#handleCloseWithSolution" styleClass="btn-primary"/>
                        <Button fx:id="attachBtn" text="📎 Datei anhängen" onAction="#handleAddAttachment" styleClass="btn-ghost"/>
                    </HBox>
                    <!-- Feature 38 – Ticket wiedereröffnen (nur für CUSTOMER bei RESOLVED/CLOSED) -->
                    <Button fx:id="reopenTicketBtn" text="Ticket wieder öffnen" onAction="#handleReopenTicket"
                            styleClass="btn-ghost" visible="false" managed="false"
                            style="-fx-text-fill: #F59E0B; -fx-border-color: #F59E0B;" />
                </VBox>
                <!-- [Nzchupa | 2026-06-13] Timeline ersetzt ListView — bessere visuelle Darstellung -->
                <!-- Timeline replaces flat ListView — shows history as visual timeline entries -->
                <Label text="Ticket-Historie" styleClass="section-title"/>
                <ScrollPane fitToWidth="true" prefHeight="280" styleClass="scroll-pane">
                    <VBox fx:id="timelineContainer" spacing="0" />
                </ScrollPane>
            </VBox>
            <VBox spacing="10" styleClass="card">
                <Label text="Kommentare" styleClass="section-title"/>
                <ListView fx:id="commentsList" VBox.vgrow="ALWAYS" styleClass="comments-list"/>
                <VBox spacing="5">
                    <TextArea fx:id="newCommentArea" prefRowCount="3" promptText="Neuer Kommentar..."/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <CheckBox fx:id="internalCheckBox" text="Interner Kommentar" />
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Senden" onAction="#handleAddComment" styleClass="btn-primary"/>
                    </HBox>
                    <Separator />
                    <Label text="Feedback nach Lösung" styleClass="section-title"/>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label fx:id="star1" text="☆" style="-fx-font-size: 28px; -fx-cursor: hand; -fx-text-fill: #94A3B8;" onMouseClicked="#handleStar1" onMouseEntered="#hoverStar1" onMouseExited="#hoverStarReset"/>
                        <Label fx:id="star2" text="☆" style="-fx-font-size: 28px; -fx-cursor: hand; -fx-text-fill: #94A3B8;" onMouseClicked="#handleStar2" onMouseEntered="#hoverStar2" onMouseExited="#hoverStarReset"/>
                        <Label fx:id="star3" text="☆" style="-fx-font-size: 28px; -fx-cursor: hand; -fx-text-fill: #94A3B8;" onMouseClicked="#handleStar3" onMouseEntered="#hoverStar3" onMouseExited="#hoverStarReset"/>
                        <Label fx:id="star4" text="☆" style="-fx-font-size: 28px; -fx-cursor: hand; -fx-text-fill: #94A3B8;" onMouseClicked="#handleStar4" onMouseEntered="#hoverStar4" onMouseExited="#hoverStarReset"/>
                        <Label fx:id="star5" text="☆" style="-fx-font-size: 28px; -fx-cursor: hand; -fx-text-fill: #94A3B8;" onMouseClicked="#handleStar5" onMouseEntered="#hoverStar5" onMouseExited="#hoverStarReset"/>
                        <Label fx:id="starValueLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #94A3B8; -fx-padding: 0 0 0 6;"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextArea fx:id="feedbackArea" prefRowCount="2" promptText="Bewertung/Feedback..." HBox.hgrow="ALWAYS" wrapText="true"/>
                        <Button fx:id="sendFeedbackBtn" text="Feedback senden" onAction="#handleSendFeedback" styleClass="btn-primary"/>
                    </HBox>
                </VBox>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
