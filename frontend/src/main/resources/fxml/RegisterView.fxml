<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ticketsystem.frontend.controller.RegisterController" stylesheets="@../css/styles.css" styleClass="register-root">
    <VBox alignment="CENTER" spacing="18" styleClass="register-card" maxWidth="430">
        <padding><Insets top="42" right="44" bottom="42" left="44" /></padding>
        <Label text="Ticket Support System" styleClass="register-brand" />
        <Label text="Konto erstellen" styleClass="register-title" />
        <Label text="Registrieren Sie sich, um Support-Tickets zu erstellen und den Status zu verfolgen." styleClass="register-subtitle" wrapText="true" textAlignment="CENTER" />
        <VBox spacing="12" maxWidth="330">
            <TextField fx:id="usernameField" promptText="Benutzername" styleClass="text-field, register-input" />
            <TextField fx:id="emailField" promptText="E-Mail" styleClass="text-field, register-input" />
            <PasswordField fx:id="passwordField" promptText="Passwort" styleClass="text-field, register-input" />
            <PasswordField fx:id="confirmPasswordField" promptText="Passwort wiederholen" styleClass="text-field, register-input" />
            <Label fx:id="errorLabel" text="Fehler" styleClass="register-error" visible="false" wrapText="true" />
            <Button text="Registrieren" onAction="#handleRegister" styleClass="btn-primary, register-button" maxWidth="Infinity" />
        </VBox>
        <Hyperlink text="Bereits ein Konto? Anmelden" onAction="#handleBackToLogin" styleClass="register-link" />
   <Button text="← Zurück" onAction="#handleBackToHome" styleClass="btn-ghost"/>
    </VBox>
</StackPane>
