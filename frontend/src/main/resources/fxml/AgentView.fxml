<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ticketsystem.frontend.controller.AgentController" stylesheets="@../css/styles.css" styleClass="root">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="210">
            <VBox>
                <padding><Insets top="20" right="16" bottom="16" left="16"/></padding>
                <Label text="Ticket Support System" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0EA5E9;" />
            </VBox>

            <Label text="TICKETS" styleClass="nav-section-label" />

            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#showMyTickets" fx:id="navMyTickets" styleClass="nav-item">
                <padding><Insets top="9" right="16" bottom="9" left="16"/></padding>
                <Circle radius="4" fill="#0EA5E9" fx:id="dotMyTickets" />
                <Label text="Meine Tickets" styleClass="text-secondary" fx:id="labelMyTickets" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="0" styleClass="badge" fx:id="sidebarBadge" style="-fx-background-color: #0EA5E9; -fx-text-fill: white;" />
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#showAllTickets" fx:id="navAllTickets" styleClass="nav-item">
                <padding><Insets top="9" right="16" bottom="9" left="16"/></padding>
                <Circle radius="4" fill="#475569" fx:id="dotAllTickets" />
                <Label text="Alle offenen Tickets" styleClass="text-secondary" fx:id="labelAllTickets" />
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#showKnowledgeBase" fx:id="navKnowledgeBase" styleClass="nav-item">
                <padding><Insets top="9" right="16" bottom="9" left="16"/></padding>
                <Circle radius="4" fill="#475569" fx:id="dotKnowledgeBase" />
                <Label text="Wissensdatenbank" styleClass="text-secondary" fx:id="labelKnowledgeBase" />
            </HBox>

            <Label text="KONTO" styleClass="nav-section-label" />

            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#handleProfile" styleClass="nav-item">
                <padding><Insets top="9" right="16" bottom="9" left="16"/></padding>
                <Circle radius="4" fill="#475569" />
                <Label text="Mein Profil" styleClass="text-secondary" />
            </HBox>

            <VBox VBox.vgrow="ALWAYS" />
            <Separator styleClass="separator" />

            <HBox spacing="10" alignment="CENTER_LEFT">
                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                <StackPane onMouseClicked="#handleProfile" style="-fx-cursor: hand;">
                    <Circle fx:id="sidebarAvatarBackground" radius="16" fill="#0EA5E9" />
                    <ImageView fx:id="sidebarProfileImage" fitWidth="32" fitHeight="32" preserveRatio="false" smooth="true" visible="false" managed="false" />
                    <Label fx:id="sidebarInitials" text="AG" style="-fx-font-size: 10px; -fx-text-fill: white; -fx-font-weight: bold;" />
                </StackPane>
                <VBox>
                    <Label fx:id="sidebarName" text="Agent" style="-fx-font-size: 13px; -fx-text-fill: #F1F5F9;" />
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Circle radius="3" fill="#22C55E" />
                        <Label text="Online" style="-fx-font-size: 11px; -fx-text-fill: #22C55E;" />
                    </HBox>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#handleLogout" styleClass="nav-item">
                <padding><Insets top="9" right="16" bottom="9" left="16"/></padding>
                <Circle radius="4" fill="#EF4444" />
                <Label text="Abmelden" styleClass="text-danger" />
            </HBox>
        </VBox>
    </left>

    <!-- TOPBAR -->
    <top>
        <HBox styleClass="topbar" prefHeight="48" alignment="CENTER_LEFT">
            <padding><Insets top="0" right="16" bottom="0" left="16"/></padding>
            <Label fx:id="breadcrumb" text="Agent  /  Meine Tickets" styleClass="text-muted" style="-fx-font-size: 12px;" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="12" alignment="CENTER">
                <!-- [Nzchupa | 2026-06-12] TS-002: Theme-Toggle-Button im Topbar hinzugefügt -->
                <!-- Theme toggle button added to topbar -->
                <Button fx:id="themeToggleBtn" text="☀" onAction="#handleToggleTheme" styleClass="btn-ghost"
                        style="-fx-font-size: 14px; -fx-padding: 4 8;" />
                <StackPane fx:id="notificationButton"
                           styleClass="notification-pill"
                           onMouseClicked="#handleNotifications"
                           style="-fx-cursor: hand;">

                    <Label text="🔔"
                           style="-fx-font-size: 16px;" />

                    <Label fx:id="notificationCountLabel"
                           text="0"
                           styleClass="notification-count"
                           StackPane.alignment="TOP_RIGHT" />

                </StackPane>
                <StackPane onMouseClicked="#handleProfile" style="-fx-cursor: hand;">
                    <Circle fx:id="topbarAvatarBackground" radius="14" fill="#0EA5E9" />
                    <ImageView fx:id="topbarProfileImage" fitWidth="28" fitHeight="28" preserveRatio="false" smooth="true" visible="false" managed="false" />
                    <Label fx:id="topbarInitials" text="AG" style="-fx-font-size: 10px; -fx-text-fill: white; -fx-font-weight: bold;" />
                </StackPane>
            </HBox>
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <StackPane>
            <!-- PANE: MEINE TICKETS -->
            <ScrollPane fx:id="paneMyTickets" fitToWidth="true" styleClass="scroll-pane">
                <VBox spacing="20">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <!-- Stat Cards -->
                    <HBox spacing="10">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <Label text="MIR ZUGEWIESEN" styleClass="stat-label" />
                            <Label fx:id="statAssigned" text="-" styleClass="stat-value, text-accent" />
                            <Label text="aktive Tickets" styleClass="stat-sub, text-muted" />
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <Label text="HEUTE GELÖST" styleClass="stat-label" />
                            <Label fx:id="statResolvedToday" text="-" styleClass="stat-value, text-success" />
                            <Label text="Tickets heute" styleClass="stat-sub, text-muted" />
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <Label text="OFFEN GESAMT" styleClass="stat-label" />
                            <Label fx:id="statOpenTotal" text="-" styleClass="stat-value, text-warning" />
                            <Label text="noch offen" styleClass="stat-sub, text-muted" />
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <Label text="KUNDENZUFRIEDENHEIT" styleClass="stat-label" />
                            <Label fx:id="statAvgRating" text="-" styleClass="stat-value, text-success" />
                            <Label text="Ø Bewertung" styleClass="stat-sub, text-muted" />
                        </VBox>
                    </HBox>

                    <HBox spacing="16">
                        <!-- Links: Meine offenen Tickets -->
                        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="12">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="MEINE OFFENEN TICKETS" styleClass="label-uppercase" />
                                <Region HBox.hgrow="ALWAYS" />
                            </HBox>
                            <VBox fx:id="assignedTicketsContainer" spacing="10">
                                <!-- Dynamically populated Ticket Cards -->
                            </VBox>
                        </VBox>

                        <!-- Rechts: Schnellantworten & Performance -->
                        <VBox spacing="16" minWidth="300" prefWidth="350">
                            <VBox styleClass="card" spacing="12">
                                <Label text="PERFORMANCE (30 TAGE)" styleClass="label-uppercase" />
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="Gelöst" prefWidth="90" styleClass="text-secondary" />
                                    <ProgressBar fx:id="perfResolvedBar" progress="0" styleClass="progress-success" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="6" />
                                    <Label fx:id="perfResolvedLabel" text="0%" styleClass="text-success" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="Offen geblieben" prefWidth="90" styleClass="text-secondary" />
                                    <ProgressBar fx:id="perfOpenBar" progress="0" styleClass="progress-danger" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="6" />
                                    <Label fx:id="perfOpenLabel" text="0%" styleClass="text-danger" />
                                </HBox>
                            </VBox>

                            <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">
                                <Label text="SCHNELLANTWORT-VORLAGEN" styleClass="label-uppercase" />

                                <VBox styleClass="ticket-card" onMouseClicked="#copyTemplate1">
                                    <Label text="Vielen Dank für Ihre Anfrage. Wir arbeiten aktiv an einer Lösung." wrapText="true" styleClass="text-secondary" />
                                </VBox>
                                <VBox styleClass="ticket-card" onMouseClicked="#copyTemplate2">
                                    <Label text="Könnten Sie uns bitte weitere Details mitteilen?" wrapText="true" styleClass="text-secondary" />
                                </VBox>
                                <VBox styleClass="ticket-card" onMouseClicked="#copyTemplate3">
                                    <Label text="Ihr Ticket wurde erfolgreich gelöst." wrapText="true" styleClass="text-secondary" />
                                </VBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </ScrollPane>

            <!-- PANE: ALLE OFFENEN TICKETS -->
            <VBox fx:id="paneAllTickets" spacing="20" visible="false">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <ComboBox fx:id="filterStatusCombo" promptText="Status" prefWidth="120" styleClass="combo-box" />
                    <ComboBox fx:id="filterPriorityCombo" promptText="Priorität" prefWidth="120" styleClass="combo-box" />
                    <TextField fx:id="searchField" promptText="Titel suchen..." prefWidth="200" styleClass="text-field" />
                    <Button text="Filtern" onAction="#handleApplyFilter" styleClass="btn-primary" />
                    <Button text="Zurücksetzen" onAction="#handleClearFilter" styleClass="btn-ghost" />
                </HBox>

                <!-- [Nzchupa | 2026-06-13] TSS-008: modern-table für bessere Lesbarkeit der Spaltenüberschriften und Trennlinien -->
                <!-- Added modern-table class for clearer column headers and row separators -->
                <TableView fx:id="ticketTable" VBox.vgrow="ALWAYS" styleClass="table-view,modern-table">
                    <columns>
                        <TableColumn fx:id="colId" text="#" prefWidth="60" />
                        <TableColumn fx:id="colTitle" text="Titel" prefWidth="250" />
                        <TableColumn fx:id="colPriority" text="Priorität" prefWidth="100" />
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="130" />
                        <TableColumn fx:id="colCreator" text="Ersteller" prefWidth="120" />
                        <TableColumn fx:id="colAgent" text="Agent" prefWidth="120" />
                        <TableColumn fx:id="colCreatedAt" text="Erstellt" prefWidth="100" />
                    </columns>
                </TableView>
            </VBox>

            <!-- PANE: WISSENSDATENBANK -->
            <VBox fx:id="paneKnowledgeBase" spacing="20" visible="false" managed="false">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <Label text="Wissensdatenbank" styleClass="heading-lg" />
                <Label text="Live Knowledge Base aus dem Backend. Doppelklick oder Button kopiert die Antwort-Vorlage." styleClass="text-muted" wrapText="true" />
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="kbSearchField" promptText="Suchen nach Software, Hardware, Passwort, VPN..." HBox.hgrow="ALWAYS" styleClass="text-field" />
                    <Button text="Suchen" onAction="#handleSearchKnowledgeBase" styleClass="btn-primary" />
                    <Button text="Vorlage kopieren" onAction="#copySelectedKbArticle" styleClass="btn-ghost" />
                </HBox>
                <ListView fx:id="kbList" VBox.vgrow="ALWAYS" styleClass="list-view" />
                <HBox spacing="16">
                    <VBox styleClass="card" spacing="12" HBox.hgrow="ALWAYS">
                        <Label text="SCHNELLVORLAGEN" styleClass="label-uppercase" />
                        <HBox spacing="10">
                            <Button text="Software" onAction="#copyKbSoftware" styleClass="btn-primary" />
                            <Button text="Hardware" onAction="#copyKbHardware" styleClass="btn-primary" />
                            <Button text="Passwort" onAction="#copyKbPassword" styleClass="btn-primary" />
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
